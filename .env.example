# =============================================================================
# FlowSync Environment Variables
# Copy this file to .env for local development.
# Use Secret Manager / GitHub Secrets for production.
# =============================================================================

# -----------------------------------------------------------------------------
# 1) NODE ENVIRONMENT
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=8080

# -----------------------------------------------------------------------------
# 2) FIREBASE & DATABASE
# -----------------------------------------------------------------------------
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_DATABASE_URL=https://your-project.firebaseio.com
# One-line JSON string. Keep private and never commit real values.
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}

# -----------------------------------------------------------------------------
# 3) GOOGLE GEMINI AI
# -----------------------------------------------------------------------------
GOOGLE_GEMINI_API_KEY=your-gemini-api-key

# -----------------------------------------------------------------------------
# 4) GOOGLE CLOUD SERVICES
# -----------------------------------------------------------------------------
# Project and region
GOOGLE_CLOUD_PROJECT_ID=your-gcp-project-id
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1

# Cloud Run and Artifact Registry
CLOUD_RUN_SERVICE=flowsync
ARTIFACT_REGISTRY_REPO=flowsync

# Cloud Storage
GOOGLE_CLOUD_STORAGE_BUCKET=your-storage-bucket
GCS_BUCKET_NAME=your-storage-bucket

# Cloud Tasks
CLOUD_TASKS_ENABLED=true
CLOUD_TASKS_LOCATION=us-central1
CLOUD_TASKS_QUEUE_NAME=flowsync-default
CLOUD_TASKS_TIMEOUT_SECONDS=30

# Cloud Logging / Monitoring / PubSub
CLOUD_LOGGING_ENABLED=true
CLOUD_LOG_NAME=flowsync-app
CLOUD_MONITORING_ENABLED=true
CLOUD_PUBSUB_ENABLED=true

# Deployment auth (optional for automation scripts)
GCP_SERVICE_ACCOUNT_EMAIL=flowsync-deployer@your-gcp-project-id.iam.gserviceaccount.com
GCP_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"..."}
CLOUD_RUN_RUNTIME_SERVICE_ACCOUNT=flowsync-runtime@your-gcp-project-id.iam.gserviceaccount.com
GCP_ACCESS_TOKEN=ya29.your-short-lived-access-token

# -----------------------------------------------------------------------------
# 5) SECURITY SETTINGS
# -----------------------------------------------------------------------------
ENFORCE_HTTPS=false
API_AUTH_TOKEN=change-me
CSRF_ENABLED=true
CSRF_SECRET=change-me
CSRF_HEADER_NAME=x-csrf-token
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=20
CORS_ORIGIN=http://localhost:8080
TRUST_PROXY=false

# -----------------------------------------------------------------------------
# 6) PERFORMANCE SETTINGS
# -----------------------------------------------------------------------------
CACHE_TTL_MS=5000
COMPRESSION_THRESHOLD=1024
MONITORING_ENABLED=true

# -----------------------------------------------------------------------------
# 7) LOGGING SETTINGS
# -----------------------------------------------------------------------------
LOG_LEVEL=info
DEBUG_MODE=false
