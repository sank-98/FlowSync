# ============================================================================
# FlowSync Environment Variables
# Copy this file to .env for local use
# For Cloud Run/GitHub Actions use Secret Manager or GitHub repository secrets
# ============================================================================

# Runtime (set to development for local dev; use production in Cloud Run)
NODE_ENV=development
PORT=8080
LOG_LEVEL=info

# Google Cloud project and deployment metadata
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1
CLOUD_RUN_SERVICE=flowsync
ARTIFACT_REGISTRY_REPO=flowsync
GCS_BUCKET_NAME=your-frontend-bucket-name

# Firebase Admin / Firestore
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_DATABASE_URL=https://your-project.firebaseio.com
# One-line JSON string. Keep private and never commit real values.
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}

# Google Gemini
GOOGLE_GEMINI_API_KEY=your-gemini-api-key

# Optional deployment auth variables for REST scripts
# Preferred in CI: store full JSON key in GitHub secret GCP_SERVICE_ACCOUNT_KEY
GCP_SERVICE_ACCOUNT_EMAIL=flowsync-deployer@your-gcp-project-id.iam.gserviceaccount.com
GCP_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"..."}
# Optional runtime identity for Cloud Run service revisions
CLOUD_RUN_RUNTIME_SERVICE_ACCOUNT=flowsync-runtime@your-gcp-project-id.iam.gserviceaccount.com
# Manual scripts can use a short-lived token instead of gcloud.
# Never commit real tokens to source control.
GCP_ACCESS_TOKEN=ya29.your-short-lived-access-token
