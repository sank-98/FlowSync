{
  "name": "flowsync",
  "version": "1.0.0",
  "description": "AI-powered stadium crowd management system for Google Prompt Wars 2024 Hackathon",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --runInBand --detectOpenHandles",
    "test:watch": "jest --watch",
    "lint": "eslint server.js public/*.js __tests__/*.js",
    "build": "echo 'No build step needed for Node.js'",
    "deploy": "bash deploy.sh",
    "test:deployment": "bash test-deployment.sh",
    "demo": "bash demo/demo-script.sh"
  },
  "keywords": [
    "stadium",
    "crowd",
    "management",
    "ai",
    "google-cloud",
    "firebase",
    "gemini",
    "hackathon"
  ],
  "author": "FlowSync Team",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "firebase-admin": "^12.0.0",
    "@google/generative-ai": "^0.3.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "jest": "^29.5.0",
    "supertest": "^6.3.3",
    "eslint": "^8.40.0"
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sank-98/FlowSync.git"
  },
  "bugs": {
    "url": "https://github.com/sank-98/FlowSync/issues"
  },
  "homepage": "https://github.com/sank-98/FlowSync#readme"
}
