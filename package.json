{
  "name": "flowsync",
  "version": "1.0.0",
  "description": "AI-powered stadium crowd management system for Google Prompt Wars 2024 Hackathon",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --runInBand --detectOpenHandles --coverage",
    "test:watch": "jest --watch",
    "test:unit": "jest tests/unit.test.js --coverage",
    "test:integration": "jest tests/integration.test.js",
    "test:e2e": "jest tests/e2e.test.js",
    "test:security": "jest tests/security.test.js",
    "test:accessibility": "jest tests/accessibility.test.js",
    "test:performance": "jest tests/performance.test.js",
    "test:load": "echo 'Run with k6: k6 run tests/load.test.js'",
    "lint": "eslint server.js public/*.js tests/**/*.js middleware/**/*.js services/**/*.js",
    "lint:security": "eslint . --plugin security",
    "security:audit": "npm audit",
    "security:scan": "snyk test",
    "sonar": "sonarqube-scanner",
    "build": "echo 'No build step needed for Node.js'",
    "deploy": "bash deploy.sh",
    "deploy:staging": "bash scripts/deploy-staging.sh",
    "deploy:production": "bash scripts/deploy-production.sh",
    "deploy:rollback": "bash scripts/rollback.sh",
    "health-check": "curl http://localhost:8080/health",
    "benchmark": "jest tests/performance.test.js",
    "setup": "bash dev-tools-setup.sh",
    "test:deployment": "bash test-deployment.sh",
    "demo": "bash demo/demo-script.sh"
  },
  "keywords": [
    "stadium",
    "crowd",
    "management",
    "ai",
    "google-cloud",
    "firebase",
    "gemini",
    "hackathon"
  ],
  "author": "FlowSync Team",
  "license": "MIT",
  "dependencies": {
    "@google-cloud/logging": "^10.0.0",
    "@google-cloud/monitoring": "^3.0.0",
    "@google-cloud/storage": "^6.0.0",
    "@google-cloud/tasks": "^4.0.0",
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "compression": "^1.7.4",
    "dotenv": "^16.0.3",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^7.0.0",
    "express-validator": "^7.0.0",
    "firebase-admin": "^12.0.0",
    "@google/generative-ai": "^0.3.0",
    "helmet": "^7.0.0",
    "redis": "^4.6.0",
    "winston": "^3.10.0"
  },
  "devDependencies": {
    "@axe-core/puppeteer": "^4.7.0",
    "axe-core": "^4.7.0",
    "cypress": "^13.0.0",
    "jest": "^29.5.0",
    "eslint": "^8.40.0"
    ,
    "eslint-plugin-security": "^1.7.1",
    "nodemon": "^3.0.1",
    "snyk": "^1.1200.0",
    "sonarqube-scanner": "^3.0.0",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sank-98/FlowSync.git"
  },
  "bugs": {
    "url": "https://github.com/sank-98/FlowSync/issues"
  },
  "homepage": "https://github.com/sank-98/FlowSync#readme"
}
