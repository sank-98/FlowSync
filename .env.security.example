# Security-focused environment configuration
NODE_ENV=production
SECURITY_ENFORCE_HTTPS=true
SECURITY_RATE_LIMIT_WINDOW_MS=900000
SECURITY_RATE_LIMIT_MAX=100
SECURITY_CSP_ENABLED=true
SECURITY_CSRF_ENABLED=true

# Sonar / Snyk
SONAR_HOST_URL=https://sonarcloud.io
SONAR_TOKEN=replace_me
SNYK_TOKEN=replace_me

# Secrets management
GOOGLE_GEMINI_API_KEY=replace_me
GOOGLE_CLOUD_PROJECT=replace_me
JWT_SECRET=replace_me

# Secret rotation procedure
# 1) Rotate in secret manager
# 2) Update runtime env
# 3) Re-deploy and verify /health endpoints

# Certificate management
TLS_CERT_PATH=/etc/ssl/certs/fullchain.pem
TLS_KEY_PATH=/etc/ssl/private/privkey.pem
